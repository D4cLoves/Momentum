# 🔒 Prevent fallback to parent .editorconfig files
root = true

##############################
# ✍️ BASIC FORMATTING
##############################

[*.cs]

charset = utf-8
end_of_line = crlf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4
tab_width = 4

##############################
# 🧱 BRACES & STRUCTURE (полезно)
##############################

csharp_prefer_braces = true:suggestion
csharp_style_expression_bodied_methods = false:suggestion
csharp_style_expression_bodied_properties = true:suggestion

##############################
# 📦 USING DIRECTIVES (полезно)
##############################

dotnet_sort_system_directives_first = true
dotnet_separate_import_directive_groups = true
csharp_using_directive_placement = outside_namespace:suggestion

##############################
# 🧬 TYPE PREFERENCES (мягко)
##############################

csharp_style_var_for_built_in_types = false:suggestion
csharp_style_var_when_type_is_apparent = false:suggestion
csharp_style_var_elsewhere = true:suggestion

##############################
# 🎯 NULL HANDLING (полезно)
##############################

dotnet_style_coalesce_expression = true:suggestion
dotnet_style_null_propagation = true:suggestion

##############################
# 🏷️ NAMING (только важное)
##############################

# Private fields: _camelCase
dotnet_naming_rule.private_fields_camel.severity = suggestion
dotnet_naming_rule.private_fields_camel.symbols = private_fields
dotnet_naming_rule.private_fields_camel.style = prefix_underscore_camel

dotnet_naming_symbols.private_fields.applicable_kinds = field
dotnet_naming_symbols.private_fields.applicable_accessibilities = private

dotnet_naming_style.prefix_underscore_camel.capitalization = camel_case
dotnet_naming_style.prefix_underscore_camel.required_prefix = _

# Public members: PascalCase
dotnet_naming_rule.public_members_pascal.severity = suggestion
dotnet_naming_rule.public_members_pascal.symbols = public_members
dotnet_naming_rule.public_members_pascal.style = pascal_case

dotnet_naming_symbols.public_members.applicable_kinds = method, property, event
dotnet_naming_symbols.public_members.applicable_accessibilities = public

dotnet_naming_style.pascal_case.capitalization = pascal_case

##############################
# 📊 STYLECOP EXCEPTIONS (отключаем бесячие)
##############################

# ❌ Отключить (не влияют на качество кода)
dotnet_diagnostic.SA1633.severity = none      # File header
dotnet_diagnostic.SA0001.severity = none      # XML comments
dotnet_diagnostic.SA1600.severity = none      # XML documentation
dotnet_diagnostic.SA1601.severity = none      # Partial elements documentation
dotnet_diagnostic.SA1602.severity = none      # Enumeration items documentation
dotnet_diagnostic.SA1611.severity = none      # Parameter documentation
dotnet_diagnostic.SA1612.severity = none      # Parameter documentation order
dotnet_diagnostic.SA1614.severity = none      # Element parameter documentation
dotnet_diagnostic.SA1615.severity = none      # Element return value documentation
dotnet_diagnostic.SA1618.severity = none      # Type parameter documentation
dotnet_diagnostic.SA1622.severity = none      # Generic type parameter documentation
dotnet_diagnostic.SA1629.severity = none      # Documentation text should end with a period
dotnet_diagnostic.SA1633.severity = none      # File header XML
dotnet_diagnostic.SA1642.severity = none      # Constructor summary documentation
dotnet_diagnostic.SA1648.severity = none      # Inheritdoc should be used with inheriting class
dotnet_diagnostic.SA1649.severity = none      # File name should match first type name

# ❌ Отключить (слишком строгие)
dotnet_diagnostic.SA1027.severity = none      # Tabs and spaces (у нас есть indent_style)
dotnet_diagnostic.SA1028.severity = none      # Code should not contain trailing whitespace
dotnet_diagnostic.SA1516.severity = none      # Elements should be separated by blank line
dotnet_diagnostic.SA1512.severity = none      # Single-line comments should not be followed by blank line
dotnet_diagnostic.SA1507.severity = none      # Code should not contain multiple blank lines in a row
dotnet_diagnostic.SA1502.severity = none      # Element should not be on a single line
dotnet_diagnostic.SA1503.severity = none      # Braces should not be omitted
dotnet_diagnostic.SA1504.severity = none      # All accessors should be single-line or multi-line
dotnet_diagnostic.SA1505.severity = none      # Opening braces should not be followed by blank line
dotnet_diagnostic.SA1508.severity = none      # Closing braces should not be preceded by blank line
dotnet_diagnostic.SA1513.severity = none      # Closing brace should be followed by blank line
dotnet_diagnostic.SA1514.severity = none      # Element documentation header should be preceded by blank line
dotnet_diagnostic.SA1515.severity = none      # Single-line comment should be preceded by blank line
dotnet_diagnostic.SA1518.severity = none      # File should end with a single newline character
dotnet_diagnostic.SA1519.severity = none      # Braces should not be omitted from multi-line child statement
dotnet_diagnostic.SA1520.severity = none      # Use braces consistently
dotnet_diagnostic.CA2007.severity = none
dotnet_diagnostic.CA1515.severity = none
dotnet_diagnostic.CA1062.severity = none
dotnet_diagnostic.CA1305.severity = none
dotnet_diagnostic.CA1031.severity = none
dotnet_diagnostic.CA1848.severity = none
dotnet_diagnostic.SA1009.severity = none
dotnet_diagnostic.CA1724.severity = none
dotnet_diagnostic.SA1313.severity = none

# ✅ Оставить включёнными (полезные)
dotnet_diagnostic.SA1101.severity = suggestion  # Prefix local calls with this
dotnet_diagnostic.SA1111.severity = suggestion  # Closing parenthesis should be on line of last parameter
dotnet_diagnostic.SA1121.severity = suggestion  # Use built-in type alias
dotnet_diagnostic.SA1122.severity = suggestion  # Use string.Empty for empty strings
dotnet_diagnostic.SA1125.severity = suggestion  # Use shorthand for nullable types
dotnet_diagnostic.SA1135.severity = suggestion  # Using directives should be qualified
dotnet_diagnostic.SA1200.severity = suggestion  # Using directives should be placed correctly
dotnet_diagnostic.SA1208.severity = suggestion  # System using directives should be placed at the top
dotnet_diagnostic.SA1210.severity = suggestion  # Using directives should be ordered alphabetically
dotnet_diagnostic.SA1309.severity = suggestion  # Field names should begin with underscore
dotnet_diagnostic.SA1310.severity = suggestion  # Field names should not contain underscore (except private)
dotnet_diagnostic.SA1413.severity = suggestion  # Use trailing comma in multi-line initializers

##############################
# 🎛 VISUAL STUDIO SPECIFIC
##############################

[*.{cs,vb,csproj,sln}]
indent_size = 4
tab_width = 4
end_of_line = crlf

[*.csproj]
indent_style = space
indent_size = 2

[*.sln]
indent_style = space
indent_size = 4

##############################
# 📄 OTHER FILE TYPES
##############################

[*.{json,xml,yaml,yml}]
indent_style = space
indent_size = 2
charset = utf-8
end_of_line = lf

[*.{md,txt}]
trim_trailing_whitespace = true
insert_final_newline = true
end_of_line = lf